---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Desafio from '../components/Desafio.astro';
import Dolores from '../components/Dolores.astro';
import ContextoOmnicanal from '../components/ContextoOmnicanal.astro';
import RelacionCliente from '../components/RelacionCliente.astro';
import Disenador from '../components/Disenador.astro';
import Principio from '../components/Principio.astro';
import CTAFooter from '../components/CTAFooter.astro';
---

<BaseLayout>
  <div class="page grid-bg">
    <Nav />
    <main>
      <Hero />
      <Desafio />
      <Dolores />
      <ContextoOmnicanal />
      <RelacionCliente />
      <Disenador />
      <Principio />
    </main>
  </div>
  <CTAFooter />
</BaseLayout>

<style>
  .page {
    background-color: var(--background);
  }
</style>
