---
// El principio (cierre de confianza): el flex humano antes del CTA final.
---

<section class="principio">
  <div class="section-wrap">
    <h2 class="principio-text">
      Las decisiones son de tu equipo.
      <br />
      <span class="italic-accent-light">Manny las ordena.</span>
    </h2>
  </div>
</section>

<style>
  /* El gap visible ARRIBA de la frase = padding-bottom de .arrancas +
     padding-top de aca (se suman). Abajo solo esta este padding-bottom. Para
     igualar, el padding-bottom incluye tambien el de .arrancas. */
  .principio {
    padding-top: var(--space-24);
    padding-bottom: calc(var(--space-24) + var(--space-16));
  }

  @media (min-width: 1024px) {
    .principio {
      padding-top: var(--space-30);
      padding-bottom: calc(var(--space-30) + var(--space-20));
    }
  }

  .principio-text {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    /* Blanco: la pagina v5 es oscura (antes usaba --foreground y quedaba
       invisible sobre el bloque). */
    color: #FFFFFF;
    text-wrap: balance;
    text-align: center;
    margin: 0 auto;
    max-width: 900px;
  }
</style>
