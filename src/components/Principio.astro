---
// El principio (cierre de confianza): el flex humano antes del CTA final.
---

<section class="principio">
  <div class="section-wrap">
    <h2 class="principio-text">
      Las decisiones son de tu equipo.
      <br />
      <span class="italic-accent">Manny las ordena.</span>
    </h2>
  </div>
</section>

<style>
  .principio {
    padding-block: var(--space-24);
  }

  @media (min-width: 1024px) {
    .principio {
      padding-block: var(--space-30);
    }
  }

  .principio-text {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    color: var(--foreground);
    text-wrap: balance;
    text-align: center;
    margin: 0 auto;
    max-width: 900px;
  }
</style>
