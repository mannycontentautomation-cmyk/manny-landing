---
// El principio (cierre de confianza): el flex humano antes del CTA final.
---

<section class="principio">
  <div class="section-wrap">
    <h2 class="principio-text">
      Las decisiones son de tu equipo.
      <br />
      <span class="italic-accent">Manny las ordena.</span>
    </h2>
    <p class="lead principio-lead">
      Manny propone, ordena y prepara. Tu equipo elige, edita y aprueba.
    </p>
  </div>
</section>

<style>
  .principio {
    padding-block: var(--space-24);
  }

  @media (min-width: 1024px) {
    .principio {
      padding-block: var(--space-30);
    }
  }

  .principio-text {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    color: var(--foreground);
    text-wrap: balance;
    margin: 0 0 var(--space-8);
    max-width: 1100px;
  }

  .principio-lead {
    margin: 0;
    max-width: 640px;
    color: var(--neutral-800);
  }
</style>
