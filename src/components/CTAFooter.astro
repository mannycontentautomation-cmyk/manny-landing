---
import MannyMark from './MannyMark.astro';
import Wordmark from './Wordmark.astro';
import WaitlistForm from './WaitlistForm.astro';

const year = new Date().getFullYear();
---

<section class="cta-block" id="beta-final">
  <div class="cta-section">
    <div class="section-wrap cta-grid">
      <h2 class="cta-h2">
        Te avisamos <span class="italic-accent-light">cuando esté lista.</span>
      </h2>

      <div class="cta-form-col">
        <p class="cta-sub">
          Estamos terminando los últimos detalles. Dejá tu mail: te
          avisamos cuando puedas entrar, o coordinamos una demo en vivo.
        </p>
        <WaitlistForm
          variant="dark"
          cta="Sumarme a la lista"
          demoCta="Quiero una demo"
          formId="cta-waitlist"
        />
      </div>
    </div>
  </div>

  <footer class="black-footer">
    <div class="section-wrap black-footer-inner">
      <a href="/" class="footer-brand" aria-label="Manny, inicio">
        <MannyMark color="white" size={28} />
        <Wordmark color="white" height={22} />
      </a>

      <span class="footer-spacer" aria-hidden="true"></span>

      <a
        href="https://www.linkedin.com/company/somosmanny"
        class="footer-social"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Manny en LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
      </a>

      <span class="footer-copy">© {year} Manny.</span>
    </div>
  </footer>
</section>

<style>
  .cta-block {
    background: var(--block-dark);
    color: #EFEFEC;
  }

  .cta-section {
    padding-top: var(--space-30);
    padding-bottom: var(--space-24);
  }

  @media (min-width: 1024px) {
    .cta-section {
      padding-top: var(--space-35);
      padding-bottom: var(--space-30);
    }
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .cta-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-20);
      align-items: center;
    }
  }

  .cta-h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    color: #FFFFFF;
    margin: 0;
    text-wrap: balance;
  }

  .cta-form-col {
    font-family: var(--font-body);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cta-sub {
    font-size: 17px;
    line-height: 1.5;
    color: rgba(239, 239, 236, 0.7);
    margin: 0;
    text-wrap: pretty;
  }

  .black-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .black-footer-inner {
    padding-top: var(--space-6);
    padding-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(239, 239, 236, 0.7);
  }

  @media (min-width: 768px) {
    .black-footer-inner {
      flex-direction: row;
      align-items: center;
      gap: var(--space-6);
    }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .footer-spacer {
    display: none;
  }

  @media (min-width: 768px) {
    .footer-spacer {
      display: block;
      flex: 1;
    }
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    color: rgba(239, 239, 236, 0.7);
    transition: color var(--duration-normal) var(--ease-default);
  }

  .footer-social:hover {
    color: #FFFFFF;
  }

  .footer-copy {
    color: rgba(239, 239, 236, 0.7);
  }
</style>
