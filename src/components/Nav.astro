---
import MannyMark from './MannyMark.astro';
import Wordmark from './Wordmark.astro';
---

<nav class="nav" aria-label="Principal">
  <div class="section-wrap nav-inner">
    <a href="/" class="nav-brand" aria-label="Manny, inicio">
      <MannyMark color="white" size={40} />
      <span class="nav-word">
        <Wordmark color="white" height={32} />
      </span>
    </a>
    <span class="nav-descriptor">La torre de control de tu agencia</span>
    <span class="nav-spacer" aria-hidden="true"></span>
    <a href="#beta-final" class="nav-demo" data-cta="nav-demo">Pedí una demo</a>
    <a href="#beta-final" class="nav-cta" data-cta="nav">Sumate a la lista</a>
  </div>
</nav>

<style>
  /* Sticky y oscuro (mismo bloque que el hero v4 y el footer): el par
     demo (outline) + lista (lleno) espeja los CTAs del hero y acompaña
     toda la página. Altura = --nav-height en tokens.css. */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding-block: var(--space-4);
    background-color: rgba(25, 23, 29, 0.88);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* En pantallas muy angostas el wordmark + CTA no entran juntos:
     queda la mascota sola a la izquierda y el CTA completo a la derecha. */
  .nav-word {
    display: none;
  }

  @media (min-width: 480px) {
    .nav-word {
      display: block;
    }
  }

  .nav-descriptor {
    display: none;
    font-family: var(--font-body);
    font-size: var(--text-body-small);
    color: rgba(239, 239, 236, 0.55);
    padding-left: var(--space-4);
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    white-space: nowrap;
  }

  @media (min-width: 900px) {
    .nav-descriptor {
      display: block;
    }
  }

  .nav-spacer {
    flex: 1;
  }

  .nav-demo {
    display: none;
    align-items: center;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: #EFEFEC;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-pill);
    padding: 8px 18px;
    white-space: nowrap;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .nav-demo:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  @media (min-width: 640px) {
    .nav-demo {
      display: inline-flex;
    }
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    border-radius: var(--radius-pill);
    padding: 9px 18px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .nav-cta:hover {
    background-color: var(--primary-hover);
  }
</style>
