---
import MannyMark from './MannyMark.astro';
import Wordmark from './Wordmark.astro';
---

<nav class="nav" aria-label="Principal">
  <div class="nav-island">
    <a href="/" class="nav-brand" aria-label="Manny, inicio">
      <MannyMark color="white" size={26} />
      <span class="nav-word">
        <Wordmark color="white" height={22} />
      </span>
    </a>
    <span class="nav-links">
      <a href="#beta-final" class="nav-demo" data-cta="nav-demo">Pedí una demo en vivo</a>
      <a href="#beta-final" class="nav-cta" data-cta="nav">Sumate a la lista</a>
    </span>
  </div>
</nav>

<style>
  /* Isla flotante: el nav ya no es una barra full-width sino una pildora
     centrada que flota sobre el contenido (sticky). Ocupa su lugar en el
     flujo, asi empuja el hero hacia abajo el espacio que necesita. */
  .nav {
    position: sticky;
    top: 16px;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding-inline: var(--space-4);
    /* Aire arriba y abajo de la isla dentro del flujo */
    margin-block: 16px 0;
  }

  .nav-island {
    display: inline-flex;
    align-items: center;
    gap: var(--space-10);
    height: 60px;
    padding: 0 12px 0 24px;
    border-radius: var(--radius-pill);
    /* Semitransparente + blur: es una isla que flota sobre el contenido al
       scrollear, no un bloque opaco. */
    background-color: rgba(32, 30, 42, 0.72);
    border: 1px solid rgba(239, 239, 236, 0.1);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    max-width: 100%;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* En pantallas muy angostas la isla se queda con la mascota sola para no
     desbordar. */
  .nav-word {
    display: none;
  }

  @media (min-width: 420px) {
    .nav-word {
      display: block;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .nav-demo {
    display: none;
    align-items: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #EFEFEC;
    text-decoration: none;
    border: 1px solid rgba(239, 239, 236, 0.28);
    border-radius: var(--radius-pill);
    height: 38px;
    padding-inline: 18px;
    white-space: nowrap;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .nav-demo:hover {
    border-color: rgba(239, 239, 236, 0.6);
  }

  /* La isla muestra los dos CTAs desde 560px; abajo queda solo el lleno. */
  @media (min-width: 560px) {
    .nav-demo {
      display: inline-flex;
    }
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    border-radius: var(--radius-pill);
    height: 38px;
    padding-inline: 20px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .nav-cta:hover {
    background-color: var(--primary-hover);
  }
</style>
