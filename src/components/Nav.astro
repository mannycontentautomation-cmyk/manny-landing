---
import MannyMark from './MannyMark.astro';
import Wordmark from './Wordmark.astro';
---

<nav class="nav" aria-label="Principal">
  <div class="section-wrap section-wrap--fluid nav-inner">
    <a href="/" class="nav-brand" aria-label="Manny, inicio">
      <MannyMark color="white" size={40} />
      <span class="nav-word">
        <Wordmark color="white" height={32} />
      </span>
    </a>
    <span class="nav-spacer" aria-hidden="true"></span>
    <a href="#beta-final" class="nav-cta" data-cta="nav">Avisame</a>
    <a href="#beta-final" class="nav-demo" data-cta="nav-demo">Pedí una demo en vivo</a>
  </div>
</nav>

<style>
  /* Sticky y oscuro (mismo bloque que el hero y el footer). Desde la v5 el
     hero no tiene botones: estos son los unicos CTAs sobre el fold, y por
     eso el nav acompaña toda la pagina. La hairline inferior es la primera
     del sistema de bandas del hero.
     Altura = --nav-height en tokens.css. */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    /* 80px de alto total = --nav-height (hairline del Figma en y=80) */
    padding-block: 20px;
    /* Mismo color que el hero, opaco: se lee como "sin fondo", solo la
       linea que lo separa. Con alpha + blur daba un gris distinto al del
       bloque. Opaco y no transparente porque es sticky: el contenido tiene
       que pasar por detras, no verse. */
    background-color: var(--block-dark);
    border-bottom: 1px solid rgba(239, 239, 236, 0.12);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* En pantallas muy angostas el wordmark + CTA no entran juntos:
     queda la mascota sola a la izquierda y el CTA completo a la derecha. */
  .nav-word {
    display: none;
  }

  @media (min-width: 480px) {
    .nav-word {
      display: block;
    }
  }

  .nav-spacer {
    flex: 1;
  }

  .nav-demo {
    display: none;
    align-items: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #EFEFEC;
    text-decoration: none;
    border: 1px solid #FFFFFF;
    border-radius: 28px;
    height: 38px;
    padding-inline: 20px;
    white-space: nowrap;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .nav-demo:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  @media (min-width: 640px) {
    .nav-demo {
      display: inline-flex;
    }
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    border-radius: 28px;
    height: 38px;
    padding-inline: 22px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .nav-cta:hover {
    background-color: var(--primary-hover);
  }
</style>
