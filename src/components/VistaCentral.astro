---
// Bloque A: la vista central. Promesa + mockup de la vista de Inicio
// (el mapa de cuentas: la torre de control literal).
// La fila de Vinoteca Peralta está viva: su chip rota por el ciclo real de
// una cuenta. Una sola fila animada, las otras quietas: es vida, no ruido.
const CUENTAS = [
  {
    cliente: 'Café Aurora',
    detalle: 'Campaña de otoño · 12 piezas',
    estado: 'En producción',
    tone: 'info',
  },
  {
    cliente: 'Vinoteca Peralta',
    detalle: 'Lanzamiento tienda online · calendario de julio',
    cycle: true,
  },
  {
    cliente: 'Librería del Sur',
    detalle: 'Contenido mensual · concepto nuevo',
    estado: 'Propuesta enviada',
    tone: 'neutral',
  },
  {
    cliente: 'Vivero Alsina',
    detalle: 'Calendario de julio · 9 piezas',
    estado: 'Aprobado',
    tone: 'ok',
  },
];

const CICLO = [
  { estado: 'Propuesta enviada', tone: 'neutral' },
  { estado: 'Espera aprobación', tone: 'warn' },
  { estado: 'Aprobado', tone: 'ok' },
  { estado: 'En producción', tone: 'info' },
];
---

<section class="benefit">
  <div class="section-wrap">
    <h2 class="display-h2 benefit-h2">
      Todo, <span class="italic-accent">de un vistazo.</span>
    </h2>
    <p class="lead benefit-lead">
      Ves el estado de cada cliente sin reconstruirlo de memoria.
    </p>

    <div
      class="mockup"
      role="img"
      aria-label="Vista de Inicio de Manny: todas las cuentas de la agencia con el estado de cada una; el estado de una cuenta avanza solo, de propuesta enviada a producción"
      data-animate
    >
      <div class="mockup-head">
        <span class="mockup-title">Inicio</span>
        <span class="mockup-meta">Todas tus cuentas</span>
        <span class="mockup-action">+ Nuevo</span>
      </div>
      <ul class="mockup-rows">
        {CUENTAS.map((c) => (
          <li class="mockup-row">
            <span class="row-avatar"></span>
            <span class="row-main">
              <span class="row-client">{c.cliente}</span>
              <span class="row-detail">{c.detalle}</span>
            </span>
            {c.cycle ? (
              <span class="row-chip chip-cycle">
                {CICLO.map((s, i) => (
                  <span
                    class="cycle-item"
                    data-tone={s.tone}
                    data-default={i === 0 ? '' : undefined}
                    style={`--i: ${i}`}
                  >
                    <span class="chip-dot"></span>
                    {s.estado}
                  </span>
                ))}
              </span>
            ) : (
              <span class="row-chip" data-tone={c.tone}>
                <span class="chip-dot"></span>
                {c.estado}
              </span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .benefit {
    padding-block: var(--space-16);
  }

  @media (min-width: 1024px) {
    .benefit {
      padding-block: var(--space-24);
    }
  }

  .benefit-h2 {
    margin: 0 0 var(--space-6);
  }

  .benefit-lead {
    margin: 0 0 var(--space-12);
    max-width: 720px;
    color: var(--neutral-800);
  }

  /* --- Mockup: vista de Inicio ---------------------------------------- */

  .mockup {
    background-color: var(--background);
    border: 1px solid var(--neutral-300);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-body);
    max-width: 960px;
  }

  .mockup-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--neutral-200);
  }

  .mockup-title {
    font-size: var(--text-body-large);
    font-weight: 700;
    color: var(--foreground);
  }

  .mockup-meta {
    font-size: 13px;
    color: var(--neutral-600);
  }

  .mockup-action {
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    border-radius: var(--radius-pill);
    padding: 6px 14px;
  }

  .mockup-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mockup-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
  }

  .mockup-row + .mockup-row {
    border-top: 1px solid var(--neutral-200);
  }

  .row-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .row-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .row-client {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
  }

  .row-detail {
    font-size: 13px;
    color: var(--neutral-600);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .row-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--neutral-800);
    border: 1px solid var(--neutral-300);
    border-radius: var(--radius-pill);
    padding: 4px 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .chip-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neutral-500);
  }

  .row-chip[data-tone='info'] .chip-dot { background-color: var(--primary); }
  .row-chip[data-tone='warn'] .chip-dot { background-color: #D97706; }
  .row-chip[data-tone='ok'] .chip-dot { background-color: #059669; }

  /* --- Chip vivo: el ciclo de vida de una cuenta ----------------------- */
  /* Los 4 estados apilados en la misma celda de grid: el chip reserva el
     ancho del label más largo y el crossfade no mueve la fila (cero shift). */

  .chip-cycle {
    display: inline-grid;
  }

  .cycle-item {
    grid-area: 1 / 1;
    justify-self: center;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    opacity: 0;
  }

  /* Estado por defecto: visible sin JS, antes del viewport y con
     reduced-motion. El ciclo arranca recién cuando el mockup entra en vista. */
  .cycle-item[data-default] {
    opacity: 1;
  }

  .cycle-item[data-tone='info'] .chip-dot { background-color: var(--primary); }
  .cycle-item[data-tone='warn'] .chip-dot { background-color: #D97706; }
  .cycle-item[data-tone='ok'] .chip-dot { background-color: #059669; }

  .mockup.in-view .cycle-item {
    animation: chip-cycle 12s linear infinite;
    animation-delay: calc(var(--i) * 3s);
    animation-fill-mode: backwards;
  }

  /* La página se siente tocable: el loop se pausa mientras mirás de cerca */
  .mockup.in-view:hover .cycle-item {
    animation-play-state: paused;
  }

  @keyframes chip-cycle {
    0% { opacity: 0; }
    3% { opacity: 1; }
    25% { opacity: 1; }
    28% { opacity: 0; }
    100% { opacity: 0; }
  }

  /* El reduced-motion global (0.01ms) convertiría el loop en estrobo:
     acá se apaga la animación y queda el estado por defecto. */
  @media (prefers-reduced-motion: reduce) {
    .mockup.in-view .cycle-item {
      animation: none;
    }
  }

  @media (max-width: 639px) {
    .row-detail {
      display: none;
    }
  }
</style>
