---
const STEPS = [
  {
    n: '01',
    title: 'Cargás el brief',
    body: 'Subís las notas de la reunión. Manny arma un brief vivo que se enriquece con cada pieza aprobada y mejora la próxima propuesta.',
  },
  {
    n: '02',
    title: 'Definís la campaña',
    body: 'Manny propone direcciones a partir del brief. Vos elegís, editás y decidís.',
  },
  {
    n: '03',
    title: 'Calendarizás',
    body: 'Armás la grilla con las piezas conectadas al brief.',
  },
  {
    n: '04',
    title: 'Disparás la producción',
    body: 'Diseñás la campaña una vez. Manny se hace cargo de la producción repetitiva, y cada pieza aprobada alimenta el brief vivo.',
  },
];
---

<section class="how" id="pipeline">
  <div class="section-wrap">
    <header class="how-header">
      <p class="eyebrow">Cómo funciona</p>
      <h2 class="display-h2 how-h2">
        El pipeline<br />
        <span class="italic-accent">en cuatro tiempos.</span>
      </h2>
    </header>

    <ol class="steps">
      {STEPS.map((step) => (
        <li class="step">
          <span class="step-num" aria-hidden="true">{step.n}</span>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how {
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 1024px) {
    .how {
      padding-top: var(--space-30);
      padding-bottom: var(--space-20);
    }
  }

  .how-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 1024px) {
    .how-header {
      margin-bottom: var(--space-16);
    }
  }

  .how-h2 {
    margin: 0;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 640px) {
    .steps {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10) var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .steps {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--neutral-300);
  }

  @media (min-width: 1024px) {
    .step {
      padding-right: var(--space-6);
      border-right: 1px solid var(--neutral-300);
      border-bottom: none;
      padding-bottom: 0;
    }

    .step:last-child {
      border-right: none;
      padding-right: 0;
    }
  }

  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-step-num);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--primary);
    margin-bottom: var(--space-5);
  }

  @media (min-width: 1024px) {
    .step-num {
      margin-bottom: var(--space-8);
    }
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-step-title);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: var(--foreground);
    margin: 0 0 var(--space-3);
    text-wrap: balance;
  }

  .step-body {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--neutral-800);
    margin: 0;
  }
</style>
