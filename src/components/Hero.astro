---
// Hero v4 (referencia NordLayer, adaptada): bloque oscuro partido en dos.
// Izquierda: titular en tres golpes (el tercero es el payoff del reframe),
// bullets como proof points, doble CTA con intención diferenciada
// (lista de espera / demo en vivo) y microcopy de riesgo.
// Derecha: el mapa de cuentas compacto con dos tarjetas narrativas
// flotando encima. La viñeta: mientras mirás una sola pantalla,
// las aprobaciones y los pedidos pasan solos.
// Proof points, no frases. Los cuatro entran en una linea y espejan, en el
// mismo orden, las cuatro columnas de Dolores (dolor -> promesa).
const BULLETS = [
  'Clientes, equipo y contenido en un solo lugar',
  'Cargás el perfil una vez y no se pierde',
  'Para el feedback, un solo link',
  'Del pedido a producción, se encarga Manny',
];

const CUENTAS = [
  { cliente: 'Café Aurora', estado: 'En producción', tone: 'info' },
  { cliente: 'Vinoteca Peralta', estado: 'Espera aprobación', tone: 'warn' },
  { cliente: 'Librería del Sur', estado: 'Propuesta enviada', tone: 'neutral' },
];
---

<section class="hero" id="producto">
  <div class="section-wrap section-wrap--fluid hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow">La torre de control de tu agencia</p>

      <h1 class="hero-h1">
        Ordená cada cuenta.<br />
        Coordiná cada entrega.<br />
        <span class="hero-payoff">Ganá tiempo para la creatividad.</span>
      </h1>

      <ul class="hero-bullets">
        {BULLETS.map((b) => (
          <li>
            <span class="bullet-dot" aria-hidden="true"></span>
            {b}
          </li>
        ))}
      </ul>

      <div class="hero-ctas">
        <a href="#beta-final" class="cta-primary" data-cta="hero">
          Sumate a la lista
          <span aria-hidden="true">→</span>
        </a>
        <a href="#beta-final" class="cta-secondary" data-cta="hero-demo">
          Pedí una demo en vivo
        </a>
      </div>

      <p class="hero-risk">
        Sin compromiso. Hasta una charla informal nos serviría para saber
        cómo ayudarte.
      </p>
    </div>

    <div
      class="hero-visual"
      role="img"
      aria-label="La vista de Inicio de Manny con las cuentas de la agencia y, flotando encima, una aprobación de cliente recién llegada y un pedido a diseño enviado"
    >
      <div class="mini-app">
        <div class="mini-head">
          <span class="mini-title">Inicio</span>
          <span class="mini-meta">Todas tus cuentas</span>
        </div>
        <ul class="mini-rows">
          {CUENTAS.map((c) => (
            <li class="mini-row">
              <span class="mini-avatar"></span>
              <span class="mini-client">{c.cliente}</span>
              <span class="mini-chip" data-tone={c.tone}>
                <span class="mini-dot"></span>
                {c.estado}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="float-card float-approval">
        <span class="fc-check" aria-hidden="true">✓</span>
        <span class="fc-main">
          <span class="fc-title">Valeria (cliente)</span>
          <span class="fc-body">Aprobó Story · lunes 13</span>
        </span>
      </div>

      <div class="float-card float-order">
        <span class="fc-avatar" aria-hidden="true"></span>
        <span class="fc-main">
          <span class="fc-title">Pedido a diseño</span>
          <span class="fc-body">Marcos · freelance</span>
        </span>
        <span class="fc-chip">Enviado</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--block-dark);
    color: #EFEFEC;
    padding-block: var(--space-16);
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: var(--space-24);
    }
  }

  /* minmax(0, ...) y no 1fr a secas: el tamaño mínimo automático de un grid
     item es su min-content, así que las filas del mockup ensanchaban la
     columna y la página scrolleaba de costado en mobile. */
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-14);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      /* La columna de copy se lleva algo mas de ancho para que el tercer
         golpe del H1 no envuelva. El mockup sigue holgado. */
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      gap: var(--space-16);
    }
  }

  /* La categoría vive en el descriptor del nav a partir de 900px; en mobile
     el descriptor se oculta, así que acá entra como eyebrow. Nunca los dos. */
  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-weight: 500;
    color: rgba(239, 239, 236, 0.55);
    margin: 0 0 var(--space-6);
  }

  @media (min-width: 900px) {
    .hero-eyebrow {
      display: none;
    }
  }

  .hero-h1 {
    font-family: var(--font-display);
    /* PRUEBA: tipografia atada al viewport, sin tope. Al escalar al mismo
       ritmo que el contenedor fluido, los cortes de linea quedan iguales en
       todos los anchos. 4.6vw es el maximo con el que el tercer golpe entra
       en una linea desde 1024px (medido: quiebra a 4.6vw, aguanta a 4.45). */
    font-size: clamp(38px, 4.4vw, 132px);
    /* tr9 usa 1.01, pero es una grotesca. La italica de Instrument Serif
       tiene descendentes largas y a 1.01 chocan con la linea de abajo. */
    line-height: 1.03;
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    color: #FFFFFF;
    text-wrap: pretty;
    margin: 0 0 var(--space-8);
  }

  .hero-payoff {
    font-style: italic;
    font-weight: 400;
    color: var(--primary-on-dark);
  }

  /* La lista se estructura con reglas, no con bullets: el mismo recurso que
     sostiene la grilla en la referencia. La regla corre a lo ancho de la
     columna y hace de renglon. */
  .hero-bullets {
    list-style: none;
    margin: 0 0 var(--space-10);
    padding: 0;
    display: flex;
    flex-direction: column;
    max-width: 640px;
    border-top: 1px solid rgba(239, 239, 236, 0.14);
  }

  .hero-bullets li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-body-large);
    line-height: 1.5;
    color: rgba(239, 239, 236, 0.82);
    padding-block: var(--space-3);
    border-bottom: 1px solid rgba(239, 239, 236, 0.14);
  }

  .bullet-dot {
    display: none;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    padding: 13px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition:
      background-color var(--duration-normal) var(--ease-default),
      transform var(--duration-normal) var(--ease-default);
  }

  .cta-primary:hover {
    background-color: var(--primary-hover);
    transform: translateY(-1px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: #EFEFEC;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.28);
    padding: 12px 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .cta-secondary:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .hero-risk {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: rgba(239, 239, 236, 0.55);
    margin: 0;
    max-width: 480px;
  }

  /* --- Visual: mapa de cuentas + tarjetas narrativas -------------------- */

  .hero-visual {
    position: relative;
    max-width: 560px;
    width: 100%;
    justify-self: center;
    /* Aire vertical = alto de tarjeta (70px) menos la mordida que queremos
       sobre el borde del mockup. Con 56px las tarjetas se apoyan en el borde
       en vez de taparle una fila entera. */
    padding-block: var(--space-14);
  }

  @media (min-width: 1024px) {
    .hero-visual {
      justify-self: end;
    }
  }

  .mini-app {
    background-color: var(--background);
    border-radius: 14px;
    overflow: hidden;
    font-family: var(--font-body);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }

  .mini-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--neutral-200);
  }

  .mini-title {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--foreground);
  }

  .mini-meta {
    font-size: 13px;
    color: var(--neutral-600);
  }

  .mini-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mini-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
  }

  .mini-row + .mini-row {
    border-top: 1px solid var(--neutral-200);
  }

  .mini-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .mini-client {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    /* Sin esto el flex item no baja de su ancho de contenido, el ellipsis
       nunca entra y la fila ensancha la columna del grid en mobile. */
    min-width: 0;
  }

  .mini-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--neutral-800);
    border: 1px solid var(--neutral-300);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mini-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neutral-500);
  }

  .mini-chip[data-tone='info'] .mini-dot { background-color: var(--primary); }
  .mini-chip[data-tone='warn'] .mini-dot { background-color: #D97706; }

  /* --- Tarjetas narrativas ---------------------------------------------- */

  .float-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background-color: var(--background);
    border-radius: 12px;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
  }

  /* En mobile las tarjetas se alinean al mockup: la sangría negativa las
     saca del viewport y hace scrollear la página de costado. */
  .float-approval {
    top: 0;
    right: 0;
  }

  .float-order {
    bottom: 0;
    left: 0;
  }

  @media (min-width: 768px) {
    .float-approval {
      right: calc(-1 * var(--space-4));
    }

    .float-order {
      left: calc(-1 * var(--space-4));
    }
  }

  @media (min-width: 1200px) {
    .float-approval {
      right: calc(-1 * var(--space-10));
    }

    .float-order {
      left: calc(-1 * var(--space-10));
    }
  }

  .fc-check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: rgba(5, 150, 105, 0.12);
    color: #059669;
    font-size: 13px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fc-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .fc-main {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .fc-title {
    font-size: 13px;
    color: var(--neutral-600);
    white-space: nowrap;
  }

  .fc-body {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
  }

  .fc-chip {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--primary);
    border: 1px solid rgba(68, 39, 255, 0.3);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
  }
</style>
