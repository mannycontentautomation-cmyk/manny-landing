---
// Hero v5 (comp Landing_design): partido. Izquierda: titular en dos golpes
// (el segundo, el payoff, en italica violeta) + bajada + doble CTA + microcopy
// de riesgo. Derecha: la vista de Inicio con dos tarjetas narrativas montadas.
const CUENTAS = [
  { cliente: 'Café Aurora', estado: 'En producción', tone: 'info' },
  { cliente: 'Vinoteca Peralta', estado: 'Espera aprobación', tone: 'warn' },
  { cliente: 'Librería del Sur', estado: 'Propuesta enviada', tone: 'neutral' },
];
---

<section class="hero" id="producto">
  <div class="section-wrap section-wrap--fluid hero-grid">
    <div class="hero-copy">
      <h1 class="hero-h1">
        Ordená cada cuenta.<br />
        <span class="hero-payoff">Ganá tiempo para la creatividad.</span>
      </h1>

      <p class="hero-sub">
        Manny es la plataforma donde tu agencia gestiona clientes, contenido
        y equipo, sin perder nada en el camino.
      </p>

      <div class="hero-ctas">
        <a href="#beta-final" class="cta-primary" data-cta="hero">
          Sumate a la lista
        </a>
        <a href="#beta-final" class="cta-secondary" data-cta="hero-demo">
          Pedí una demo en vivo
        </a>
      </div>

      <p class="hero-risk">
        Sin compromiso. Contanos cómo trabajás hoy y te mostramos cómo Manny
        puede adaptarse a tu agencia.
      </p>
    </div>

    <div
      class="hero-visual"
      role="img"
      aria-label="La vista de Inicio de Manny con las cuentas de la agencia y, flotando encima, una aprobación de cliente recién llegada y un pedido a diseño enviado"
    >
      <div class="mini-app">
        <div class="mini-head">
          <span class="mini-title">Inicio</span>
          <span class="mini-meta">Todas tus cuentas</span>
        </div>
        <ul class="mini-rows">
          {CUENTAS.map((c) => (
            <li class="mini-row">
              <span class="mini-avatar"></span>
              <span class="mini-client">{c.cliente}</span>
              <span class="mini-chip" data-tone={c.tone}>
                <span class="mini-dot"></span>
                {c.estado}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="float-card float-approval">
        <span class="fc-check" aria-hidden="true">✓</span>
        <span class="fc-main">
          <span class="fc-title">Valeria (cliente)</span>
          <span class="fc-body">Aprobó Story · lunes 13</span>
        </span>
      </div>

      <div class="float-card float-order">
        <span class="fc-avatar" aria-hidden="true"></span>
        <span class="fc-main">
          <span class="fc-title">Pedido a diseño</span>
          <span class="fc-body">Marcos · freelance</span>
        </span>
        <span class="fc-chip">Enviado</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--block-dark);
    color: #EFEFEC;
    padding-block: clamp(48px, 7vh, 104px) clamp(64px, 9vh, 140px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(48px, 6vw, 88px);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      /* Texto un poco mas ancho que el grafico, como en el comp */
      grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    }
  }

  /* --- Izquierda: copy -------------------------------------------------- */

  .hero-h1 {
    font-family: var(--font-display);
    /* ~68px a 1512; escala con el viewport sin tope real */
    font-size: clamp(40px, 4.5vw, 92px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    font-weight: 400;
    color: #FFFFFF;
    margin: 0;
    text-wrap: balance;
  }

  .hero-payoff {
    font-style: italic;
    color: var(--primary-on-dark);
  }

  .hero-sub {
    margin: var(--space-6) 0 0;
    max-width: 30em;
    font-family: var(--font-body);
    font-size: var(--text-lead);
    line-height: 1.5;
    color: rgba(239, 239, 236, 0.72);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    height: 48px;
    padding-inline: 26px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default),
      border-color var(--duration-normal) var(--ease-default);
  }

  .cta-primary {
    color: var(--primary-foreground);
    background-color: var(--primary);
  }

  .cta-primary:hover {
    background-color: var(--primary-hover);
  }

  .cta-secondary {
    color: #EFEFEC;
    border: 1px solid rgba(239, 239, 236, 0.28);
  }

  .cta-secondary:hover {
    border-color: rgba(239, 239, 236, 0.6);
  }

  .hero-risk {
    margin: var(--space-5) 0 0;
    max-width: 34em;
    font-family: var(--font-body);
    font-size: var(--text-body-small);
    line-height: 1.5;
    color: rgba(239, 239, 236, 0.5);
  }

  /* --- Derecha: la vista de Inicio + tarjetas --------------------------- */

  .hero-visual {
    position: relative;
    width: 100%;
    justify-self: center;
    /* Aire para que las tarjetas montadas no se recorten */
    padding-block: var(--space-12);
  }

  @media (min-width: 1024px) {
    .hero-visual {
      justify-self: end;
      max-width: 560px;
    }
  }

  .mini-app {
    background-color: var(--background);
    border-radius: 18px;
    overflow: hidden;
    font-family: var(--font-body);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }

  .mini-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--neutral-200);
  }

  .mini-title {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--foreground);
  }

  .mini-meta {
    font-size: 13px;
    color: var(--neutral-800);
  }

  .mini-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mini-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
  }

  .mini-row + .mini-row {
    border-top: 1px solid var(--neutral-200);
  }

  .mini-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .mini-client {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .mini-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--neutral-800);
    border: 1px solid var(--neutral-300);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mini-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neutral-500);
    flex-shrink: 0;
  }

  .mini-chip[data-tone='info'] .mini-dot { background-color: var(--primary); }
  .mini-chip[data-tone='warn'] .mini-dot { background-color: #B45309; }

  /* --- Tarjetas narrativas ---------------------------------------------- */

  .float-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background-color: var(--background);
    border-radius: 12px;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    box-shadow: 0 4px 30px rgba(25, 23, 29, 0.15), 0 16px 40px rgba(0, 0, 0, 0.4);
  }

  .float-approval {
    top: 0;
    right: 0;
  }

  .float-order {
    bottom: 0;
    left: 0;
  }

  @media (min-width: 768px) {
    .float-approval {
      right: calc(-1 * var(--space-6));
    }

    .float-order {
      left: calc(-1 * var(--space-6));
    }
  }

  .fc-check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: rgba(5, 150, 105, 0.12);
    color: #047857;
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fc-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .fc-main {
    display: flex;
    flex-direction: column;
  }

  .fc-title {
    font-size: 13px;
    color: var(--neutral-800);
  }

  .fc-body {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
  }

  .fc-chip {
    font-size: 13px;
    font-weight: 500;
    color: var(--primary);
    border: 1px solid var(--primary);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    margin-left: var(--space-2);
    white-space: nowrap;
  }
</style>
