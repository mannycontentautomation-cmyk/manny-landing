---
// Hero v5. Valores tomados del Figma (node 150:294, frame 1512x982):
// bandas full-bleed separadas por hairlines en y=80 / 364 / 756, gutter de
// 84px (5.56vw), H1 Instrument Serif Regular 100px (6.61vw) en redonda con
// interlineado efectivo 1.05, proof points de 24px con check.
// Los CTAs viven solo en el nav sticky.
const BULLETS = [
  'Clientes, equipo y contenido en un solo lugar.',
  'Cargás el perfil una vez y no se pierde.',
  'Para el feedback, un solo link.',
  'Del pedido a producción, se encarga Manny.',
];

const CUENTAS = [
  { cliente: 'Café Aurora', estado: 'En producción', tone: 'info' },
  { cliente: 'Vinoteca Peralta', estado: 'Espera aprobación', tone: 'warn' },
  { cliente: 'Librería del Sur', estado: 'Propuesta enviada', tone: 'neutral' },
];
---

<section class="hero" id="producto">
  <!-- Banda 1: el titular, solo (284px de 982 en el Figma) -->
  <div class="hero-band hero-band-title">
    <div class="section-wrap section-wrap--fluid">
      <h1 class="hero-h1">
        Ordená y coordiná la gestión.<br />
        <span class="hero-payoff">Ganá tiempo para la creatividad.</span>
      </h1>
    </div>
  </div>

  <!-- Banda 2: el producto (392px) -->
  <div class="hero-band hero-band-visual">
    <div class="section-wrap section-wrap--fluid">
      <div
        class="visual-row"
        role="img"
        aria-label="La vista de Inicio de Manny con las cuentas de la agencia y, flotando encima, una aprobación de cliente recién llegada y un pedido a diseño enviado"
      >
        <!-- Cluster izquierdo: el calendario -->
        <div class="tile-cal" aria-hidden="true">
          <span class="tile-cal-head"></span>
          <span class="tile-cal-grid">
            {Array.from({ length: 12 }).map(() => <span></span>)}
          </span>
        </div>

        <div class="sat sat-cal" aria-hidden="true">
          <span class="sat-plus">+</span>
          Creá un calendario
        </div>

        <!-- Centro: la vista de Inicio -->
        <div class="mini-app">
          <div class="mini-head">
            <span class="mini-title">Inicio</span>
            <span class="mini-meta">Todas tus cuentas</span>
          </div>
          <ul class="mini-rows">
            {CUENTAS.map((c) => (
              <li class="mini-row">
                <span class="mini-avatar"></span>
                <span class="mini-client">{c.cliente}</span>
                <span class="mini-chip" data-tone={c.tone}>
                  <span class="mini-dot"></span>
                  {c.estado}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Las dos tarjetas montadas sobre el borde derecho del mockup -->
        <div class="float-card float-approval">
          <span class="fc-check" aria-hidden="true">✓</span>
          <span class="fc-main">
            <span class="fc-title">Valeria (cliente)</span>
            <span class="fc-body">Aprobó Story · lunes 13</span>
          </span>
        </div>

        <div class="float-card float-order">
          <span class="fc-avatar" aria-hidden="true"></span>
          <span class="fc-main">
            <span class="fc-title">Pedido a diseño</span>
            <span class="fc-body">Marcos · freelance</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Banda 3: proof points + bajada (226px) -->
  <div class="hero-band hero-band-facts">
    <div class="section-wrap section-wrap--fluid facts-row">
      <ul class="hero-bullets">
        {BULLETS.map((b) => (
          <li>
            <svg class="check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 12.5l5 5L20 6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {b}
          </li>
        ))}
      </ul>
      <a href="#desafio" class="scroll-cue" aria-label="Ir a la siguiente sección">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 4v16m0 0l-6-6m6 6l6-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* El hero ocupa el viewport completo. Las bandas del titular y de los
     proof points se dimensionan por contenido; la del producto se queda con
     el resto, que es como se comporta en el Figma (284 / 392 / 226). */
  .hero {
    background-color: var(--block-dark);
    color: #EFEFEC;
    min-height: calc(100vh - var(--nav-height));
    display: grid;
    grid-template-rows: auto 1fr auto;
    /* minmax(0,...) y no 1fr suelto: el minimo automatico de un grid item es
       su min-content, y el mockup ensanchaba la columna en mobile. */
    grid-template-columns: minmax(0, 1fr);
  }

  /* Full-bleed: la hairline cruza toda la pantalla y es lo que estructura
     el bloque. El contenido si respeta el contenedor fluido. */
  .hero-band + .hero-band {
    border-top: 1px solid rgba(239, 239, 236, 0.12);
  }

  .hero-band-title {
    display: flex;
    align-items: center;
    padding-block: clamp(32px, 5vh, 76px);
  }

  .hero-band-visual {
    display: flex;
    align-items: center;
    padding-block: clamp(20px, 2.8vh, 44px);
  }

  /* Mas aire que las otras dos: es la banda que cierra contra el borde
     inferior del viewport y necesita no quedar pegada. */
  .hero-band-facts {
    display: flex;
    align-items: center;
    padding-block: clamp(28px, 5vh, 64px);
  }

  .hero-band > .section-wrap {
    width: 100%;
  }

  /* --- Banda 1: el titular --------------------------------------------- */

  .hero-h1 {
    font-family: var(--font-display);
    /* 6.61vw = los 100px del Figma a 1512. El min() con vh lo ata tambien
       a la altura: en pantallas anchas y bajas el titular crecia por ancho
       y empujaba la banda de abajo fuera del viewport.
       10.2vh = esos mismos 100px sobre los 982 de alto del Figma. */
    font-size: clamp(32px, min(6.61vw, 10.2vh), 172px);
    /* En el Figma cada linea es un parrafo absoluto con line-height 93 pero
       separados 105px: el interlineado efectivo es 1.05, no 0.93. A 0.93 se
       pisan las descendentes de la serif. */
    line-height: 1.05;
    letter-spacing: 0;
    font-weight: 400;
    color: #FFFFFF;
    margin: 0;
    text-wrap: pretty;
  }

  /* Redonda, no italica: el Figma marca not-italic. */
  .hero-payoff {
    color: #A79FFF;
  }

  /* --- Banda 2: el producto -------------------------------------------- */

  .visual-row {
    position: relative;
    display: flex;
    justify-content: center;
    /* Aire para que las tarjetas montadas no tapen una fila del mockup */
    padding-block: clamp(20px, 3vh, 48px);
  }

  .mini-app {
    background-color: var(--background);
    border-radius: 20px;
    overflow: hidden;
    font-family: var(--font-body);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    width: 100%;
    /* En mobile ocupa el ancho util; desde 1024 vale el 45% del Figma
       (604 de 1344 de contenido). Sin min-width en px: a 320 se desborda. */
    max-width: 100%;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .mini-app {
      max-width: 45%;
    }
  }

  .mini-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--neutral-200);
  }

  .mini-title {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--foreground);
  }

  .mini-meta {
    font-size: 13px;
    /* neutral-600 sobre blanco da 3.74:1, por debajo de AA */
    color: var(--neutral-800);
  }

  .mini-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mini-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
  }

  .mini-row + .mini-row {
    border-top: 1px solid var(--neutral-200);
  }

  .mini-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .mini-client {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    /* Sin esto el flex item no baja de su ancho de contenido, el ellipsis
       nunca entra y la fila ensancha la columna en mobile. */
    min-width: 0;
  }

  .mini-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--neutral-800);
    border: 1px solid var(--neutral-300);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mini-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neutral-500);
    flex-shrink: 0;
  }

  .mini-chip[data-tone='info'] .mini-dot { background-color: var(--primary); }
  .mini-chip[data-tone='warn'] .mini-dot { background-color: #B45309; }

  /* En pantallas de menos de 1000px de alto el mockup se comprime, asi el
     hero entra entero sin tener que recortarle aire a las bandas. */
  @media (max-height: 1000px) {
    .mini-row { padding-block: var(--space-2); }
    .mini-head { padding-block: var(--space-3); }
  }

  /* --- Piezas satelite -------------------------------------------------- */

  .tile-cal,
  .sat,
  .float-card {
    display: none;
  }

  .sat {
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    padding: 4px 18px 4px 4px;
    white-space: nowrap;
    height: 38px;
  }

  .sat-cal {
    background-color: #E7E7E7;
    border: 1px solid #CCCCCC;
    color: var(--foreground);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .sat-plus {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--primary);
    color: var(--primary-foreground);
    font-size: 16px;
    line-height: 1;
    flex-shrink: 0;
  }

  .tile-cal {
    flex-direction: column;
    gap: 10px;
    background-color: #A79FFF;
    border-radius: 20px;
    padding: 16px;
    width: 13.4%;
    aspect-ratio: 180 / 202;
  }

  .tile-cal-head {
    display: block;
    height: 8px;
    width: 60%;
    border-radius: 4px;
    background-color: rgba(25, 23, 29, 0.25);
  }

  .tile-cal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    flex: 1;
  }

  .tile-cal-grid span {
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.55);
  }

  .float-card {
    align-items: center;
    gap: var(--space-3);
    background-color: var(--background);
    border-radius: 14px;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    box-shadow: 0 4px 30px rgba(25, 23, 29, 0.15), 0 16px 40px rgba(0, 0, 0, 0.4);
  }

  /* La composicion flotante necesita aire. Debajo de 1024px queda el mockup
     solo, que es el dato; los satelites se ocultan. */
  @media (min-width: 1024px) {
    .tile-cal,
    .sat,
    .float-card {
      display: flex;
      position: absolute;
    }

    /* Posiciones en % del ancho de contenido, tomadas del Figma */
    .tile-cal {
      left: 14.1%;
      top: 12%;
    }

    .sat-cal {
      left: 6.6%;
      top: 52%;
    }

    /* El Figma las pone en 69.8%, montadas 78px sobre el bloque central.
       Ahi el bloque es un placeholder vacio; aca abajo hay un chip de
       estado con texto. Anclamos al borde derecho del mockup (centrado y
       45% de ancho => termina en 72.5%) con una mordida FIJA de 12px: por
       porcentaje la mordida crecia con el ancho y volvia a cortar el chip,
       que vive 20px adentro del borde. */
    .float-approval {
      left: calc(72.5% - 12px);
      top: 14%;
    }

    .float-order {
      left: calc(72.5% - 12px);
      top: 52%;
    }
  }

  .fc-check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: rgba(5, 150, 105, 0.12);
    color: #047857;
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fc-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .fc-main {
    display: flex;
    flex-direction: column;
  }

  .fc-title {
    font-size: 13px;
    color: var(--neutral-800);
  }

  .fc-body {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
  }

  /* --- Banda 3: proof points ------------------------------------------- */

  .facts-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .hero-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-bullets li {
    display: flex;
    align-items: center;
    gap: 21px;
    font-family: var(--font-body);
    /* 24px del Figma, con interlineado de 40px */
    font-size: clamp(16px, 1.6vw, 24px);
    line-height: 40px;
    color: #EFEFEC;
  }

  .check {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: #EFEFEC;
  }

  .scroll-cue {
    display: none;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background-color: #FFFFFF;
    color: var(--foreground);
    text-decoration: none;
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .scroll-cue svg {
    width: 22px;
    height: 22px;
  }

  .scroll-cue:hover {
    transform: translateY(3px);
  }

  @media (min-width: 768px) {
    .scroll-cue {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue:hover {
      transform: none;
    }
  }
</style>
