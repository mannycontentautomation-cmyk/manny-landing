---
// Hero v5: layout en bandas horizontales full-bleed separadas por hairlines.
// El titular deja de compartir fila con el grafico y se lleva una banda
// entera: la tipografia pasa a ser el layout. Debajo, la banda del producto
// y la banda de proof points con el indicador de scroll.
// Los CTAs viven solo en el nav sticky, que acompaña toda la pagina.
const BULLETS = [
  'Clientes, equipo y contenido en un solo lugar.',
  'Cargás el perfil una vez y no se pierde.',
  'Para el feedback, un solo link.',
  'Del pedido a producción, se encarga <b>Manny</b>.',
];

const CUENTAS = [
  { cliente: 'Café Aurora', estado: 'En producción', tone: 'info' },
  { cliente: 'Vinoteca Peralta', estado: 'Espera aprobación', tone: 'warn' },
  { cliente: 'Librería del Sur', estado: 'Propuesta enviada', tone: 'neutral' },
];
---

<section class="hero" id="producto">
  <!-- Banda 1: el titular, solo -->
  <div class="hero-band hero-band-title">
    <div class="section-wrap section-wrap--fluid">
      <h1 class="hero-h1">
        Ordená y coordiná la gestión.<br />
        <span class="hero-payoff">Ganá tiempo para la creatividad.</span>
      </h1>
    </div>
  </div>

  <!-- Banda 2: el producto -->
  <div class="hero-band hero-band-visual">
    <div class="section-wrap section-wrap--fluid">
      <div
        class="visual-row"
        role="img"
        aria-label="La vista de Inicio de Manny con las cuentas de la agencia y, flotando encima, una aprobación de cliente recién llegada y un pedido a diseño enviado"
      >
        <!-- Satelite propio del hero: no se repite en Desafio -->
        <div class="sat-calendario" aria-hidden="true">
          <span class="sat-plus">+</span>
          Creá un calendario
        </div>

        <div class="mini-app">
          <div class="mini-head">
            <span class="mini-title">Inicio</span>
            <span class="mini-meta">Todas tus cuentas</span>
          </div>
          <ul class="mini-rows">
            {CUENTAS.map((c) => (
              <li class="mini-row">
                <span class="mini-avatar"></span>
                <span class="mini-client">{c.cliente}</span>
                <span class="mini-chip" data-tone={c.tone}>
                  <span class="mini-dot"></span>
                  {c.estado}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="float-card float-approval">
          <span class="fc-check" aria-hidden="true">✓</span>
          <span class="fc-main">
            <span class="fc-title">Valeria (cliente)</span>
            <span class="fc-body">Aprobó Story · lunes 13</span>
          </span>
        </div>

        <div class="float-card float-order">
          <span class="fc-avatar" aria-hidden="true"></span>
          <span class="fc-main">
            <span class="fc-title">Pedido a diseño</span>
            <span class="fc-body">Marcos · freelance</span>
          </span>
          <span class="fc-chip">Enviado</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Banda 3: proof points + bajada al resto de la pagina -->
  <div class="hero-band hero-band-facts">
    <div class="section-wrap section-wrap--fluid facts-row">
      <ul class="hero-bullets">
        {BULLETS.map((b) => <li set:html={b} />)}
      </ul>
      <a href="#desafio" class="scroll-cue" aria-label="Ir a la siguiente sección">
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--block-dark);
    color: #EFEFEC;
  }

  /* Las bandas son full-bleed: la hairline cruza toda la pantalla y es lo
     que estructura el bloque. El contenido de cada banda si respeta el
     contenedor fluido. */
  .hero-band + .hero-band {
    border-top: 1px solid rgba(239, 239, 236, 0.12);
  }

  /* Los espaciados van en vh y no en vw: el hero tiene que entrar en una
     pantalla, y lo que lo aprieta es el alto, no el ancho. En un viewport
     bajo las bandas se comprimen solas. */
  .hero-band-title {
    padding-block: clamp(28px, 4.5vh, 72px);
  }

  .hero-band-visual {
    padding-block: clamp(20px, 3vh, 48px);
  }

  .hero-band-facts {
    padding-block: clamp(18px, 2.5vh, 32px);
  }

  /* --- Banda 1: el titular --------------------------------------------- */

  .hero-h1 {
    font-family: var(--font-display);
    /* Atada al viewport y sin tope real: escala con el contenedor fluido,
       asi los cortes de linea no se mueven entre 1024 y 1920. */
    /* 6.5vw = el titular llena ~72% de la banda en cualquier ancho, igual
       que el mock. Medido de 1024 a 1920: siempre 2 lineas, 72%. */
    font-size: clamp(34px, 6.5vw, 180px);
    /* La italica de Instrument Serif tiene descendentes largas: por debajo
       de 1.03 chocan con el renglon siguiente. */
    line-height: 1.03;
    letter-spacing: var(--tracking-h2);
    font-weight: 500;
    color: #FFFFFF;
    margin: 0;
    text-wrap: pretty;
  }

  .hero-payoff {
    font-style: italic;
    font-weight: 400;
    color: var(--primary-on-dark);
  }

  /* --- Banda 2: el producto -------------------------------------------- */

  .visual-row {
    position: relative;
    display: flex;
    justify-content: center;
    /* Aire = alto de tarjeta (~65px) menos la mordida buscada sobre el
       borde del mockup. Con menos, las tarjetas tapan una fila entera. */
    padding-block: var(--space-14);
  }

  .mini-app {
    background-color: var(--background);
    border-radius: 14px;
    overflow: hidden;
    font-family: var(--font-body);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    width: 100%;
    max-width: 680px;
  }

  .mini-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--neutral-200);
  }

  .mini-title {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--foreground);
  }

  .mini-meta {
    font-size: 13px;
    /* neutral-600 sobre blanco da 3.74:1, por debajo de AA */
    color: var(--neutral-800);
  }

  .mini-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mini-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
  }

  .mini-row + .mini-row {
    border-top: 1px solid var(--neutral-200);
  }

  .mini-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .mini-client {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    /* Sin esto el flex item no baja de su ancho de contenido, el ellipsis
       nunca entra y la fila ensancha la columna en mobile. */
    min-width: 0;
  }

  .mini-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    font-size: 13px;
    font-weight: 500;
    color: var(--neutral-800);
    border: 1px solid var(--neutral-300);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mini-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--neutral-500);
    flex-shrink: 0;
  }

  .mini-chip[data-tone='info'] .mini-dot { background-color: var(--primary); }
  .mini-chip[data-tone='warn'] .mini-dot { background-color: #B45309; }

  /* Notebooks de pantalla baja (1280x800, 1024x768): el mockup se comprime
     para que el hero siga entrando en una pantalla. */
  @media (max-height: 860px) {
    .mini-row {
      padding-block: var(--space-2);
    }

    .mini-head {
      padding-block: var(--space-3);
    }
  }

  /* --- Satelites y tarjetas -------------------------------------------- */

  .sat-calendario {
    display: none;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    background-color: var(--neutral-200);
    border-radius: var(--radius-pill);
    padding: 8px 16px 8px 8px;
    white-space: nowrap;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .sat-plus {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: var(--primary);
    color: var(--primary-foreground);
    font-size: 15px;
    line-height: 1;
    flex-shrink: 0;
  }

  .float-card {
    display: none;
    align-items: center;
    gap: var(--space-3);
    background-color: var(--background);
    border-radius: 12px;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
  }

  /* Debajo de 900px la composicion flotante no tiene aire: queda el mockup
     solo, que es el dato, y los satelites se ocultan. */
  @media (min-width: 900px) {
    .sat-calendario,
    .float-card {
      display: flex;
      position: absolute;
    }

    .sat-calendario {
      left: 0;
      bottom: 18%;
    }

    .float-approval {
      top: 0;
      right: 4%;
    }

    .float-order {
      bottom: 0;
      left: 16%;
    }
  }

  @media (min-width: 1280px) {
    .float-approval { right: 12%; }
    .float-order { left: 22%; }
  }

  .fc-check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: rgba(5, 150, 105, 0.12);
    color: #047857;
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fc-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: var(--neutral-200);
    flex-shrink: 0;
  }

  .fc-main {
    display: flex;
    flex-direction: column;
  }

  .fc-title {
    font-size: 13px;
    color: var(--neutral-800);
  }

  .fc-body {
    font-size: var(--text-body-small);
    font-weight: 500;
    color: var(--foreground);
    white-space: nowrap;
  }

  .fc-chip {
    font-size: 13px;
    font-weight: 500;
    color: var(--primary);
    border: 1px solid var(--primary);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    margin-left: var(--space-2);
    white-space: nowrap;
  }

  /* --- Banda 3: proof points ------------------------------------------- */

  .facts-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .hero-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-bullets li {
    font-family: var(--font-body);
    font-size: var(--text-body-large);
    line-height: 1.75;
    color: rgba(239, 239, 236, 0.82);
  }

  .hero-bullets :global(b) {
    font-weight: 700;
    color: #FFFFFF;
  }

  .scroll-cue {
    display: none;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: #FFFFFF;
    color: var(--foreground);
    font-size: 20px;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .scroll-cue:hover {
    transform: translateY(3px);
  }

  @media (min-width: 768px) {
    .scroll-cue {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue:hover {
      transform: none;
    }
  }
</style>
