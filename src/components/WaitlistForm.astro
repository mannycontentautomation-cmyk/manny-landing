---
type Variant = 'primary' | 'dark';

interface Props {
  variant?: Variant;
  cta?: string;
  placeholder?: string;
  formId?: string;
}

const {
  variant = 'primary',
  cta = 'Sumarme a la beta',
  placeholder = 'tu@email.com',
  formId = 'waitlist',
} = Astro.props;
---

<form
  class:list={['waitlist', variant === 'dark' ? 'is-dark' : 'is-light']}
  data-form-id={formId}
  novalidate
>
  <div class="pill">
    <input
      type="email"
      name="email"
      placeholder={placeholder}
      required
      autocomplete="email"
      aria-label="Tu email"
    />
    <button type="submit">
      <span class="btn-label">{cta}</span>
    </button>
  </div>

  <label class="demo-check">
    <input type="checkbox" name="demo" />
    <span>Quiero una demo en vivo</span>
  </label>

  <p class="status" data-status="idle" aria-live="polite"></p>
</form>

<style>
  .waitlist {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 460px;
    width: 100%;
  }

  .pill {
    display: flex;
    gap: var(--space-2);
    padding: 6px;
    border-radius: var(--radius-pill);
    width: 100%;
  }

  .waitlist.is-light .pill {
    background: #FFFFFF;
    border: 1px solid var(--border);
    box-shadow: 0 1px 2px rgba(25, 23, 29, 0.04);
  }

  .waitlist.is-dark .pill {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  /* El intent de demo: el CTA secundario del hero lo pre-marca
     (data-intent-demo en BaseLayout), pero el visitante manda. */
  .demo-check {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    cursor: pointer;
    width: max-content;
    color: var(--neutral-800);
  }

  .waitlist.is-dark .demo-check {
    color: rgba(239, 239, 236, 0.75);
  }

  .demo-check input {
    width: 16px;
    height: 16px;
    accent-color: var(--primary);
    cursor: pointer;
  }

  .pill input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    outline: none;
    font-size: 15px;
    padding: 0 var(--space-5);
    font-family: inherit;
    color: var(--foreground);
  }

  .waitlist.is-dark .pill input {
    color: #EFEFEC;
  }

  .pill input::placeholder {
    color: var(--neutral-500);
  }

  .waitlist.is-dark .pill input::placeholder {
    color: rgba(239, 239, 236, 0.5);
  }

  .waitlist button {
    background: var(--primary);
    color: #FFFFFF;
    border: none;
    border-radius: var(--radius-pill);
    padding: 12px 22px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .waitlist button:hover {
    background: var(--primary-hover);
  }

  .waitlist button:active {
    background: var(--primary-active);
  }

  .waitlist button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .status {
    margin: 0;
    padding-inline: 6px;
    font-size: 13px;
    line-height: 1.4;
    color: var(--neutral-600);
    min-height: 1em;
    pointer-events: none;
  }

  .waitlist.is-dark .status {
    color: rgba(239, 239, 236, 0.7);
  }

  .status[data-status="error"] {
    color: #B91C1C;
  }

  .waitlist.is-dark .status[data-status="error"] {
    color: #FCA5A5;
  }

  .status[data-status="success"] {
    color: var(--primary);
  }

  .waitlist.is-dark .status[data-status="success"] {
    color: var(--primary-on-dark);
  }

  @media (max-width: 480px) {
    .pill {
      flex-direction: column;
      padding: 12px;
      border-radius: 16px;
    }
    .pill input {
      padding: 10px var(--space-3);
    }
    .waitlist button {
      width: 100%;
    }
  }
</style>

<script>
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  document.querySelectorAll<HTMLFormElement>('form.waitlist').forEach((form) => {
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const input = form.querySelector<HTMLInputElement>('input[type="email"]');
    const status = form.querySelector<HTMLElement>('.status');
    if (!button || !input || !status) return;

    const formId = form.dataset.formId || 'waitlist';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (input.value || '').trim();

      if (!EMAIL_RE.test(email)) {
        status.dataset.status = 'error';
        status.textContent = 'Email inválido. Probá de nuevo.';
        input.focus();
        return;
      }

      button.disabled = true;
      status.dataset.status = 'idle';
      status.textContent = 'Sumándote…';

      // El CTA por el que llegó el visitante (hero / nav) lo guarda el
      // script de BaseLayout en sessionStorage; sin click previo, "direct".
      let via = 'direct';
      try {
        via = sessionStorage.getItem('manny-cta') || 'direct';
      } catch {
        /* sessionStorage bloqueado */
      }

      const demoCheck = form.querySelector<HTMLInputElement>('input[name="demo"]');
      const intent = demoCheck?.checked ? 'demo' : 'waitlist';

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: `${formId}:${via}`, intent }),
        });

        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          alreadySignedUp?: boolean;
          error?: string;
        };

        if (!res.ok || !data.ok) {
          if (data.error === 'invalid_email') {
            status.dataset.status = 'error';
            status.textContent = 'Email inválido. Probá de nuevo.';
          } else {
            status.dataset.status = 'error';
            status.textContent = 'Algo salió mal. Probá de nuevo en un rato.';
          }
          return;
        }

        status.dataset.status = 'success';
        if (intent === 'demo') {
          status.textContent = data.alreadySignedUp
            ? 'Ya estabas en la lista. Te escribimos para coordinar la demo.'
            : '¡Listo! Te escribimos para coordinar la demo.';
        } else {
          status.textContent = data.alreadySignedUp
            ? 'Ya estabas en la lista. Te avisamos cuando llegue tu turno.'
            : '¡Sumado! Revisá tu mail para confirmar.';
        }
        input.value = '';
      } catch (_err) {
        status.dataset.status = 'error';
        status.textContent = 'Algo salió mal. Probá de nuevo en un rato.';
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
