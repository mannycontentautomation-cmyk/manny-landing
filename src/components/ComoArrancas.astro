---
// Sección onboarding (referencia NordLayer "How to deploy"): FONDO CLARO.
// Corta el arco oscuro de arriba. Eyebrow + H2 numerado + subhead que mata
// la objeción de implementación, 3 pasos con número en cuadrado violeta +
// laptop wireframe (contorno liviano) con mini-tarjeta blanca adentro, y
// remate: CTA centrado a la demo en vivo (pre-marca el checkbox del form).
// OJO: no es el "proceso en 4 tiempos" de la v3 (aquel era el pipeline del
// producto como columna vertebral). Este cuenta lo fácil que es arrancar.
---

<section class="arrancas">
  <div class="section-wrap">
    <header class="arrancas-head">
      <p class="arrancas-eyebrow">Cómo arrancás</p>
      <h2 class="display-h2 arrancas-h2">
        Ordená tu agencia <span class="italic-accent">en tres pasos.</span>
      </h2>
      <p class="arrancas-sub">
        Una sola plataforma, todas las herramientas. Cargás tu primer
        cliente y arrancás a trabajar el mismo día.
      </p>
    </header>

    <ol class="pasos">
      <li class="paso">
        <div class="laptop" aria-hidden="true">
          <span class="paso-num">1</span>
          <div class="screen">
            <div class="card card-perfil">
              <span class="cp-head">Perfil · Café Aurora</span>
              <ul class="cp-checks">
                <li><span class="cp-check">✓</span> Identidad</li>
                <li><span class="cp-check">✓</span> Tono</li>
                <li><span class="cp-check">✓</span> Audiencia</li>
              </ul>
            </div>
          </div>
        </div>
        <h3 class="paso-titulo">Cargá el perfil del cliente</h3>
        <p class="paso-cuerpo">
          Subí el brief, las notas de reunión y los lineamientos de la
          marca. Manny los estructura en un perfil vivo.
        </p>
      </li>

      <li class="paso">
        <div class="laptop" aria-hidden="true">
          <span class="paso-num">2</span>
          <div class="screen">
            <div class="card card-cal">
              <span class="cc-head">Calendario · julio</span>
              <div class="cc-meta">
                <span class="cc-pill">12 piezas</span>
                <span class="cc-pill">3 canales</span>
              </div>
              <div class="cc-grid">
                <span></span><span class="on"></span><span></span>
                <span class="on"></span><span></span><span class="on"></span>
              </div>
            </div>
          </div>
        </div>
        <h3 class="paso-titulo">Armá la campaña y su calendario</h3>
        <p class="paso-cuerpo">
          Manny propone direcciones a partir del perfil. Vos elegís,
          editás y aprobás el plan.
        </p>
      </li>

      <li class="paso">
        <div class="laptop" aria-hidden="true">
          <span class="paso-num">3</span>
          <div class="screen">
            <div class="card card-share">
              <span class="cs-row">
                <span class="cs-link">manny.tools/c/aurora</span>
              </span>
              <span class="cs-chip cs-ok">Cliente aprobó</span>
              <span class="cs-chip cs-sent">Pedido enviado a diseño</span>
            </div>
          </div>
        </div>
        <h3 class="paso-titulo">Compartí y producí</h3>
        <p class="paso-cuerpo">
          Tu cliente aprueba con un link y los pedidos salen armados a
          diseño. Todo queda registrado.
        </p>
      </li>
    </ol>

    <div class="arrancas-cta">
      <a href="#beta-final" class="cta-primary" data-cta="arrancas-demo">
        Pedí una demo en vivo
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .arrancas {
    background-color: var(--background);
    padding-block: var(--space-24);
  }

  @media (min-width: 1024px) {
    .arrancas {
      padding-block: var(--space-30);
    }
  }

  .arrancas-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    margin-bottom: var(--space-16);
  }

  .arrancas-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--primary);
    margin: 0;
  }

  .arrancas-h2 {
    margin: 0;
    max-width: 820px;
  }

  .arrancas-sub {
    font-family: var(--font-body);
    font-size: var(--text-body-large);
    line-height: 1.55;
    color: var(--neutral-800);
    margin: 0;
    max-width: 620px;
    text-wrap: pretty;
  }

  /* --- Pasos ------------------------------------------------------------- */

  /* La columna sube a 2 y luego a 3 recién cuando cada columna puede
     contener la laptop de tamaño fijo (264px) sin encogerla. Así las tres
     laptops quedan idénticas en todos los formatos. */
  .pasos {
    list-style: none;
    margin: 0 0 var(--space-16);
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-14);
  }

  @media (min-width: 760px) {
    .pasos {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12) var(--space-10);
    }
  }

  @media (min-width: 1140px) {
    .pasos {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  /* Tamaño fijo del bloque (laptop + textos), centrado en su columna. */
  .paso {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 296px;
    margin-inline: auto;
  }

  /* Laptop wireframe: solo contorno, liviana. Ancho fijo = idéntica siempre. */
  .laptop {
    position: relative;
    width: 100%;
    margin-bottom: var(--space-8);
    padding: 0 var(--space-4) var(--space-5);
  }

  .paso-num {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--primary);
    color: var(--primary-foreground);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    border-radius: 8px;
  }

  .screen {
    position: relative;
    margin-top: var(--space-6);
    border: 1.5px solid var(--neutral-300);
    border-radius: 12px 12px 0 0;
    background-color: #FAFAF8;
    /* Alto fijo (no aspect-ratio) para que las tres pantallas sean iguales
       sin importar el ancho de columna. Apaisada (~1.4:1) para leer como
       laptop; la tarjeta cae centrada y flota adentro. */
    height: 184px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* Base de la laptop */
  .laptop::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 10px;
    border: 1.5px solid var(--neutral-300);
    border-radius: 0 0 10px 10px;
    background-color: #F0F0EC;
  }

  /* Mini-tarjetas: ancho fijo, flotan centradas dentro de la pantalla. */
  .card {
    width: 200px;
    background-color: var(--background);
    border: 1px solid var(--neutral-200);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(25, 23, 29, 0.08);
    padding: var(--space-4);
    font-family: var(--font-body);
  }

  /* Paso 1: perfil con checks */
  .cp-head {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: var(--space-3);
  }

  .cp-checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cp-checks li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--neutral-800);
  }

  .cp-check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background-color: rgba(5, 150, 105, 0.12);
    color: #059669;
    font-size: 13px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Paso 2: calendario */
  .cc-head {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: var(--space-3);
  }

  .cc-meta {
    display: flex;
    gap: 6px;
    margin-bottom: var(--space-3);
  }

  .cc-pill {
    font-size: 13px;
    font-weight: 500;
    color: var(--primary);
    background-color: var(--primary-light);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
  }

  /* Slots anchos, 2 filas x 3 columnas: leen como espacios de contenido
     del calendario. Altura fija (con aspect-ratio se estiraban al ancho
     y desbordaban la laptop). */
  .cc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .cc-grid span {
    height: 30px;
    border-radius: 6px;
    background-color: var(--neutral-200);
  }

  .cc-grid span.on {
    background-color: var(--primary-light);
    border: 1px solid rgba(68, 39, 255, 0.25);
  }

  /* Paso 3: compartir + producir */
  .card-share {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cs-row {
    display: flex;
  }

  .cs-link {
    font-size: 13px;
    color: var(--neutral-600);
    background-color: var(--neutral-200);
    border-radius: 6px;
    padding: 6px 10px;
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cs-chip {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    padding: 4px 10px;
    width: max-content;
  }

  .cs-ok {
    color: #059669;
    border: 1px solid rgba(5, 150, 105, 0.3);
  }

  .cs-sent {
    color: var(--primary);
    border: 1px solid rgba(68, 39, 255, 0.3);
  }

  .paso-titulo {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--foreground);
    margin: 0 0 var(--space-3);
    text-wrap: balance;
  }

  .paso-cuerpo {
    font-family: var(--font-body);
    font-size: var(--text-body-small);
    line-height: 1.55;
    color: var(--neutral-800);
    margin: 0;
    text-wrap: pretty;
  }

  /* --- CTA de remate ----------------------------------------------------- */

  .arrancas-cta {
    display: flex;
    justify-content: center;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--primary-foreground);
    background-color: var(--primary);
    padding: 14px 30px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition:
      background-color var(--duration-normal) var(--ease-default),
      transform var(--duration-normal) var(--ease-default);
  }

  .cta-primary:hover {
    background-color: var(--primary-hover);
    transform: translateY(-1px);
  }
</style>
