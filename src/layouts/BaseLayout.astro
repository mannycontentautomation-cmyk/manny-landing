---
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Manny · El pipeline de producción para equipos creativos',
  description = 'Propuesta, brief, calendario y producción de piezas. En un solo flujo, con el contexto de cada cliente viajando de principio a fin. Pensado para agencias creativas, estudios y equipos in-house.',
  ogImage = '/assets/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = Astro.site!.toString().replace(/\/$/, '');

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteURL}/#organization`,
      name: 'Manny',
      url: siteURL,
      logo: `${siteURL}/logo.png`,
      description:
        'Pipeline de producción para agencias creativas. La agencia sube el brief y el contexto del cliente; Manny procesa esa información para generar piezas específicas. El control de cada decisión es siempre de la agencia.',
      sameAs: ['https://www.linkedin.com/company/somosmanny'],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteURL}/#website`,
      url: siteURL,
      name: 'Manny',
      description,
      inLanguage: 'es-AR',
      publisher: { '@id': `${siteURL}/#organization` },
    },
  ],
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#4427FF" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Manny" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="es_AR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
